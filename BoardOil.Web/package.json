{
  "name": "boardoil-web",
  "version": "0.2.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite --host 0.0.0.0 --port 5173",
    "lint": "eslint --max-warnings=0 --config eslint.config.js \"src/api/**/*Api.ts\"",
    "typecheck": "vue-tsc --noEmit",
    "test": "vitest run",
    "sync:third-party-licences": "node ./scripts/sync-third-party-licences.mjs",
    "check": "npm run lint && npm run typecheck && npm run build",
    "build": "npm run sync:third-party-licences && vite build",
    "preview": "vite preview --host 0.0.0.0 --port 4173"
  },
  "dependencies": {
    "@microsoft/signalr": "^10.0.0",
    "@tiptap/extension-link": "^3.20.4",
    "@tiptap/markdown": "^3.20.4",
    "@tiptap/pm": "^3.20.4",
    "@tiptap/starter-kit": "^3.20.4",
    "@tiptap/vue-3": "^3.20.4",
    "emoji-picker-element": "^1.29.1",
    "lucide-vue-next": "^0.577.0",
    "pinia": "^3.0.4",
    "vue": "^3.5.13",
    "vue-router": "^4.6.4"
  },
  "devDependencies": {
    "@vitejs/plugin-vue": "^5.2.1",
    "@typescript-eslint/parser": "^8.0.0",
    "eslint": "^9.0.0",
    "typescript": "^5.7.3",
    "vite": "^6.0.11",
    "vitest": "^4.1.0",
    "vue-tsc": "^3.2.5"
  }
}
