{
  "name": "boardoil-web",
  "version": "1.0.0",
  "private": true,
  "license": "MIT",
  "type": "module",
  "scripts": {
    "dev": "npm run sync:third-party-licences && VITE_BO_VERSION=${VITE_BO_VERSION:-$npm_package_version} vite --host 0.0.0.0 --port 5173",
    "lint": "eslint --max-warnings=0 --config eslint.config.js \"src/shared/api/**/*Api.ts\"",
    "typecheck": "vue-tsc --noEmit",
    "test": "vitest run",
    "verify-release": "npm run check && npm test",
    "sync:third-party-licences": "node ./scripts/sync-third-party-licences.mjs --publish-public",
    "check": "npm run lint && npm run typecheck && npm run build",
    "build": "npm run sync:third-party-licences && VITE_BO_VERSION=${VITE_BO_VERSION:-$npm_package_version} vite build",
    "preview": "vite preview --host 0.0.0.0 --port 4173"
  },
  "dependencies": {
    "@microsoft/signalr": "^10.0.0",
    "@tiptap/extension-link": "^3.22.3",
    "@tiptap/markdown": "^3.22.3",
    "@tiptap/pm": "^3.22.3",
    "@tiptap/starter-kit": "^3.22.3",
    "@tiptap/vue-3": "^3.22.3",
    "emoji-picker-element": "^1.29.1",
    "lucide-vue-next": "^1.0.0",
    "pinia": "^3.0.4",
    "vue": "^3.5.32",
    "vue-router": "^5.0.4"
  },
  "devDependencies": {
    "@typescript-eslint/parser": "^8.58.2",
    "@vitejs/plugin-vue": "^6.0.6",
    "eslint": "^10.2.1",
    "picomatch": "^4.0.4",
    "typescript": "^6.0.3",
    "vite": "^8.0.8",
    "vitest": "^4.1.4",
    "vue-tsc": "^3.2.6"
  }
}
