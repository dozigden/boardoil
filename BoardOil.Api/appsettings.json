{
  "BoardOil": {
    "DataPath": "/data/boardoil.db",
    "ImageRootPath": "/data/images",
    "ExposeLan": false,
    "Port": 5000
  },
  "BoardOilAuth": {
    "Issuer": "boardoil",
    "Audience": "boardoil",
    "SigningKey": "replace-this-with-a-strong-32-char-min-signing-key",
    "AccessTokenMinutes": 15,
    "RefreshTokenDays": 14,
    "AccessTokenCookieName": "boardoil_access",
    "RefreshTokenCookieName": "boardoil_refresh",
    "AllowInsecureCookies": false
  },
  "BoardOilCsrf": {
    "CookieName": "boardoil_csrf",
    "HeaderName": "X-BoardOil-CSRF"
  },
  "BoardOilMcp": {
    "TransportMode": "http",
    "AuthMode": "pat",
    "AnonymousActorUserId": 1
  },
  "ConnectionStrings": {
    "BoardOil": "Data Source=/data/boardoil.db"
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*"
}
