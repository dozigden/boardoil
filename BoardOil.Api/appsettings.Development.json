{
  "BoardOil": {
    "DataPath": "boardoil.dev.db",
    "ExposeLan": false,
    "Port": 5000
  },
  "BoardOilAuth": {
    "Issuer": "boardoil-dev",
    "Audience": "boardoil-dev",
    "SigningKey": "boardoil-dev-signing-key-change-me-1234567890",
    "AccessTokenMinutes": 15,
    "RefreshTokenDays": 14,
    "AccessTokenCookieName": "boardoil_access",
    "RefreshTokenCookieName": "boardoil_refresh",
    "AllowInsecureCookies": true
  },
  "BoardOilCsrf": {
    "CookieName": "boardoil_csrf",
    "HeaderName": "X-BoardOil-CSRF"
  },
  "ConnectionStrings": {
    "BoardOil": "Data Source=boardoil.dev.db"
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  }
}
